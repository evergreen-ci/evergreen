{
  "tests": [
    {
      "query_file": "success.graphql",
      "result": { "data": { "attachVolumeToHost": true } }
    },
    {
      "query_file": "different_availability_zones.graphql",
      "result": {
        "errors": [
          {
            "message": "host and volume must have same availability zone",
            "path": ["attachVolumeToHost"],
            "extensions": { "code": "INPUT_VALIDATION_ERROR" }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "empty_host.graphql",
      "result": {
        "errors": [
          {
            "message": "must specify host ID(s)",
            "path": ["attachVolumeToHost", "volumeAndHost", "hostId"],
            "extensions": {
              "code": "RESOURCE_NOT_FOUND"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "empty_volume.graphql",
      "result": {
        "errors": [
          {
            "message": "must specify volume ID",
            "path": ["attachVolumeToHost", "volumeAndHost", "volumeId"],
            "extensions": {
              "code": "INPUT_VALIDATION_ERROR"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "nonexistent_host.graphql",
      "result": {
        "errors": [
          {
            "message": "No matching hosts found",
            "path": ["attachVolumeToHost", "volumeAndHost", "hostId"],
            "extensions": {
              "code": "RESOURCE_NOT_FOUND"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "nonexistent_volume.graphql",
      "result": {
        "errors": [
          {
            "message": "volume 'vol-4db5' not found",
            "path": ["attachVolumeToHost", "volumeAndHost", "volumeId"],
            "extensions": {
              "code": "RESOURCE_NOT_FOUND"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "no_permissions.graphql",
      "test_user_id": "regular_user",
      "result": {
        "errors": [
          {
            "message": "user 'regular_user' does not have permission to access volume 'vol-0603934da6f024db5'",
            "path": ["attachVolumeToHost", "volumeAndHost", "volumeId"],
            "extensions": {
              "code": "FORBIDDEN"
            }
          }
        ],
        "data": null
      }
    }
  ]
}
