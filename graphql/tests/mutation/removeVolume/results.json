{
  "tests": [
    {
      "query_file": "mounted_volume_success.graphql",
      "result": { "data": { "removeVolume": true } }
    },
    {
      "query_file": "nonexistent_volume.graphql",
      "result": {
        "errors": [
          {
            "message": "volume 'not-real' not found",
            "path": ["removeVolume", "volumeId"],
            "extensions": {
              "code": "RESOURCE_NOT_FOUND"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "empty_volume.graphql",
      "result": {
        "errors": [
          {
            "message": "volume not specified",
            "path": ["removeVolume", "volumeId"],
            "extensions": {
              "code": "INPUT_VALIDATION_ERROR"
            }
          }
        ],
        "data": null
      }
    },
    {
      "query_file": "unmounted_volume_success.graphql",
      "result": { "data": { "removeVolume": true } }
    },
    {
      "query_file": "no_permissions.graphql",
      "test_user_id": "regular_user",
      "result": {
        "data": null,
        "errors": [
          {
            "message": "user 'regular_user' does not have permission to access volume 'vol-createdByAdmin'",
            "path": ["removeVolume", "volumeId"],
            "extensions": {
              "code": "FORBIDDEN"
            }
          }
        ]
      }
    }
  ]
}
